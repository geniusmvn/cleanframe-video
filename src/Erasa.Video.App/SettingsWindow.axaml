<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Erasa.Video.App.SettingsWindow"
        Width="620" Height="430" CanResize="False" WindowStartupLocation="CenterOwner"
        Title="Cài đặt ERASA VIDEO" Icon="/Assets/erasa.ico">
  <Grid Margin="24" RowDefinitions="Auto,Auto,Auto,Auto,*,Auto" RowSpacing="14">
    <TextBlock Text="Cài đặt" FontSize="24" FontWeight="Bold" />
    <Grid Grid.Row="1" ColumnDefinitions="130,*" ColumnSpacing="12">
      <TextBlock Text="Thư mục lưu" VerticalAlignment="Center" />
      <TextBox Grid.Column="1" x:Name="OutputBox" />
    </Grid>
    <Grid Grid.Row="2" ColumnDefinitions="130,*" ColumnSpacing="12">
      <TextBlock Text="Thiết bị" VerticalAlignment="Center" />
      <ComboBox Grid.Column="1" x:Name="DeviceBox" SelectedIndex="0">
        <ComboBoxItem Content="Tự động" Tag="Auto" />
        <ComboBoxItem Content="NVIDIA GPU" Tag="Nvidia" />
        <ComboBoxItem Content="CPU" Tag="Cpu" />
      </ComboBox>
    </Grid>
    <Border Grid.Row="3" Background="#FFF8F2" BorderBrush="#F2D6C1" BorderThickness="1" CornerRadius="9" Padding="12">
      <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="8" ColumnSpacing="12">
        <StackPanel>
          <TextBlock Text="Gói tăng tốc NVIDIA" FontWeight="Bold" />
          <TextBlock Text="Artifact mặc định chạy CPU. Bấm một lần để ứng dụng tự tải và cài PyTorch CUDA 11.1 cho GTX 1660 Super; không cần CMD hay PowerShell." TextWrapping="Wrap" Foreground="#6D655F" Margin="0,4,0,0" />
        </StackPanel>
        <Button Grid.Column="1" x:Name="InstallGpuButton" Classes="primary" Content="Cài gói NVIDIA" Click="InstallGpu_Click" VerticalAlignment="Center" />
        <ProgressBar Grid.Row="1" Grid.ColumnSpan="2" x:Name="GpuInstallProgress" IsIndeterminate="True" IsVisible="False" Height="5" />
        <TextBlock Grid.Row="2" Grid.ColumnSpan="2" x:Name="GpuInstallStatus" Text="Gói tải khá lớn; chỉ cài khi cần GPU." TextWrapping="Wrap" Foreground="#6D655F" />
      </Grid>
    </Border>
    <TextBlock Grid.Row="4" Text="CPU luôn dùng được. Tự động sẽ dùng NVIDIA khi gói CUDA đã được cài và driver tương thích, nếu không sẽ chuyển về CPU." TextWrapping="Wrap" Foreground="#6D655F" />
    <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
      <Button Content="Hủy" Click="Cancel_Click" />
      <Button Classes="primary" Content="Lưu" Click="Save_Click" />
    </StackPanel>
  </Grid>
</Window>
