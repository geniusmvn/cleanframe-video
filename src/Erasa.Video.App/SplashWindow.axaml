<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Erasa.Video.App.SplashWindow"
        Width="900" Height="520" CanResize="False"
        SystemDecorations="None" WindowStartupLocation="CenterScreen"
        Background="White" TransparencyLevelHint="AcrylicBlur">
  <Grid>
    <Image Source="/Assets/erasa-splash.png" Stretch="Uniform" Margin="80" />
    <ProgressBar IsIndeterminate="True" Height="3" VerticalAlignment="Bottom" Foreground="#FF6B00" />
  </Grid>
</Window>
