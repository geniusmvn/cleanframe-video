<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Erasa.Video.App.Controls"
        xmlns:core="using:Erasa.Video.Core.Models"
        x:Class="Erasa.Video.App.MainWindow"
        Width="1360" Height="820" MinWidth="1120" MinHeight="700"
        WindowStartupLocation="CenterScreen" Title="ERASA VIDEO"
        Icon="/Assets/erasa.ico" Background="#FFFDFC" DragDrop.AllowDrop="True">
  <Grid RowDefinitions="96,44,*,92">
    <Border Grid.Row="0" Background="White" BorderBrush="#E8E2DC" BorderThickness="0,0,0,1" Padding="22,13">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="20">
        <StackPanel Orientation="Horizontal" Spacing="14">
          <Image Source="/Assets/erasa-icon.png" Width="54" Height="54" />
          <StackPanel VerticalAlignment="Center" Spacing="2">
            <StackPanel Orientation="Horizontal" Spacing="9">
              <TextBlock Text="ERASA VIDEO" FontSize="24" FontWeight="Bold" Foreground="#171717" />
              <Border Background="#FFF0E6" BorderBrush="#FF6B00" BorderThickness="1" CornerRadius="5" Padding="6,2" VerticalAlignment="Center">
                <TextBlock Text="v0.2.0" Foreground="#FF6B00" FontSize="11" FontWeight="Bold" />
              </Border>
            </StackPanel>
            <TextBlock Text="LaMa gốc • xử lý ảnh và video theo mask người dùng xác nhận" Foreground="#756E68" FontSize="12" />
          </StackPanel>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
          <Button Content="Chọn tệp" Click="AddFiles_Click" Background="Transparent" />
          <Button Content="Thêm thư mục" Click="AddFolder_Click" Background="Transparent" />
          <Button Content="Mở thư mục gốc" Click="OpenSourceFolder_Click" Background="Transparent" />
          <Button Content="Thư mục lưu" Click="OpenOutputFolder_Click" Background="Transparent" />
          <Button Content="Cài đặt" Click="Settings_Click" Background="Transparent" />
          <Button Content="Thoát" Click="Exit_Click" Background="Transparent" />
        </StackPanel>
      </Grid>
    </Border>

    <Border Grid.Row="1" Background="White" BorderBrush="#E8E2DC" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="140,140,*,Auto" Margin="22,0">
        <Button x:Name="VideoTab" Content="Video" Classes="tool selected" Click="VideoTab_Click" BorderThickness="0" />
        <Button Grid.Column="1" x:Name="ImageTab" Content="Ảnh" Classes="tool" Click="ImageTab_Click" BorderThickness="0" />
        <TextBlock Grid.Column="3" x:Name="SelectedCountText" Text="Chưa chọn tệp" VerticalAlignment="Center" Foreground="#756E68" />
      </Grid>
    </Border>

    <Grid Grid.Row="2" ColumnDefinitions="*,390" ColumnSpacing="12" Margin="12,10,12,8">
      <Border Classes="card" Padding="10">
        <Grid RowDefinitions="54,*,78,38" RowSpacing="8">
          <Border Background="#FCF9F5" CornerRadius="9" BorderBrush="#E8E2DC" BorderThickness="1" Padding="10,7">
            <Grid ColumnDefinitions="110,Auto,Auto,*,Auto" ColumnSpacing="8">
              <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Border Width="28" Height="28" CornerRadius="5" Background="#FF6B00"><TextBlock Text="1" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" /></Border>
                <TextBlock Text="CÁCH XÓA" FontWeight="Bold" VerticalAlignment="Center" />
              </StackPanel>
              <Button Grid.Column="1" x:Name="AutoButton" Classes="primary" Content="Tự động đề xuất" Click="Suggest_Click" />
              <Button Grid.Column="2" x:Name="ManualButton" Content="Chọn vùng thủ công" Click="Manual_Click" />
              <Border Grid.Column="4" Background="#232323" CornerRadius="4" Padding="7,3" VerticalAlignment="Center">
                <TextBlock Text="PREVIEW" Foreground="White" FontSize="11" FontWeight="Bold" />
              </Border>
            </Grid>
          </Border>

          <Border Grid.Row="1" Background="#0D1115" CornerRadius="8" ClipToBounds="True">
            <ScrollViewer x:Name="EditorScroll" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
              <controls:MaskEditor x:Name="Editor" MinWidth="640" MinHeight="360" />
            </ScrollViewer>
          </Border>

          <Grid Grid.Row="2" RowDefinitions="38,34" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <StackPanel Orientation="Horizontal" Spacing="7">
              <Button x:Name="BrushTool" Classes="tool selected" Content="Cọ" Click="Tool_Click" Tag="Brush" />
              <Button x:Name="EraserTool" Classes="tool" Content="Tẩy" Click="Tool_Click" Tag="Eraser" />
              <Button x:Name="RectTool" Classes="tool" Content="Khung" Click="Tool_Click" Tag="Rectangle" />
              <Button x:Name="EllipseTool" Classes="tool" Content="Elip" Click="Tool_Click" Tag="Ellipse" />
              <Button x:Name="PanTool" Classes="tool" Content="Pan" Click="Tool_Click" Tag="Pan" />
              <TextBlock Text="Cỡ cọ" VerticalAlignment="Center" Margin="10,0,0,0" />
              <Slider x:Name="BrushSlider" Minimum="0.004" Maximum="0.10" Value="0.025" Width="130" ValueChanged="BrushSlider_Changed" />
              <TextBlock Text="Mềm" VerticalAlignment="Center" />
              <Slider x:Name="SoftnessSlider" Minimum="0" Maximum="1" Value="0.2" Width="100" ValueChanged="SoftnessSlider_Changed" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
              <Button Content="Hoàn tác" Click="Undo_Click" />
              <Button Content="Làm lại" Click="Redo_Click" />
              <Button Content="Đặt lại" Click="ClearMask_Click" />
            </StackPanel>
            <Grid Grid.Row="1" Grid.ColumnSpan="2" ColumnDefinitions="42,*,50,Auto,Auto,Auto" ColumnSpacing="8">
              <TextBlock x:Name="CurrentTimeText" Text="00:00" VerticalAlignment="Center" />
              <Slider Grid.Column="1" x:Name="Timeline" Minimum="0" Maximum="1" Value="0" ValueChanged="Timeline_Changed" />
              <TextBlock Grid.Column="2" x:Name="DurationText" Text="00:00" VerticalAlignment="Center" />
              <Button Grid.Column="3" Content="−" Click="ZoomOut_Click" Padding="10,4" />
              <TextBlock Grid.Column="4" x:Name="ZoomText" Text="100%" VerticalAlignment="Center" MinWidth="42" TextAlignment="Center" />
              <Button Grid.Column="5" Content="+" Click="ZoomIn_Click" Padding="10,4" />
            </Grid>
          </Grid>

          <Grid Grid.Row="3" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
            <TextBlock x:Name="HintText" Text="Thêm tệp để bắt đầu." VerticalAlignment="Center" Foreground="#655D57" />
            <Button Grid.Column="1" Content="Preview 3 giây" Click="Preview_Click" />
            <Button Grid.Column="2" Content="Quét lại" Click="Suggest_Click" />
          </Grid>
        </Grid>
      </Border>

      <Border Grid.Column="1" Classes="card" Padding="12">
        <Grid RowDefinitions="46,*,44" RowSpacing="8">
          <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="7">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <TextBlock Text="Danh sách xử lý" FontSize="19" FontWeight="Bold" />
              <Border Background="#F4F1EE" CornerRadius="8" Padding="8,3"><TextBlock x:Name="QueueCountText" Text="0 tệp" Foreground="#756E68" /></Border>
            </StackPanel>
            <Button Grid.Column="1" Content="Thêm" Click="AddFiles_Click" Padding="10,6" />
            <Button Grid.Column="2" Content="Bỏ danh sách" Click="ClearQueue_Click" Padding="10,6" />
          </Grid>
          <ListBox Grid.Row="1" x:Name="QueueList" SelectionChanged="QueueList_SelectionChanged" Background="Transparent" BorderThickness="0">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border BorderBrush="#DED7D0" BorderThickness="1" CornerRadius="9" Margin="0,0,0,8" Padding="8">
                  <Grid ColumnDefinitions="42,86,*,Auto" ColumnSpacing="9">
                    <Border Background="#FFF5EC" CornerRadius="6" Width="38" Height="38" VerticalAlignment="Top">
                      <TextBlock Text="{Binding StatusText}" FontSize="9" TextWrapping="Wrap" TextAlignment="Center" VerticalAlignment="Center" Foreground="#FF6B00" />
                    </Border>
                    <Border Grid.Column="1" Background="#111" CornerRadius="5" Width="86" Height="52" ClipToBounds="True">
                      <Image Source="{Binding PreviewPath, Converter={StaticResource PathBitmapConverter}}" Stretch="UniformToFill" />
                    </Border>
                    <StackPanel Grid.Column="2" Spacing="3">
                      <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                      <TextBlock Text="{Binding ResolutionText}" FontSize="11" Foreground="#756E68" />
                      <ProgressBar Minimum="0" Maximum="1" Value="{Binding Progress}" Height="3" />
                    </StackPanel>
                    <Button Grid.Column="3" Content="×" Click="RemoveItem_Click" Tag="{Binding}" Padding="7,3" VerticalAlignment="Top" />
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
          <TextBlock Grid.Row="2" Text="Kéo thả ảnh hoặc video vào cửa sổ để thêm nhanh." TextWrapping="Wrap" Foreground="#817970" FontSize="11" VerticalAlignment="Center" />
        </Grid>
      </Border>
    </Grid>

    <Border Grid.Row="3" Margin="12,0,12,12" Classes="card" Padding="12">
      <Grid ColumnDefinitions="190,*,Auto,Auto,Auto,Auto" ColumnSpacing="9">
        <Button x:Name="ProcessButton" Classes="primary" Content="XỬ LÝ" FontSize="21" Click="Process_Click" />
        <Grid Grid.Column="1" RowDefinitions="Auto,Auto" VerticalAlignment="Center">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock x:Name="StatusText" Text="Sẵn sàng" FontWeight="Bold" />
            <TextBlock Grid.Column="1" x:Name="BatchProgressText" Text="0 / 0 hoàn thành" FontWeight="SemiBold" />
          </Grid>
          <ProgressBar Grid.Row="1" x:Name="BatchProgress" Minimum="0" Maximum="1" Height="8" Margin="0,9,0,0" />
        </Grid>
        <Button Grid.Column="2" x:Name="PauseButton" Content="Tạm dừng" Click="Pause_Click" IsEnabled="False" />
        <Button Grid.Column="3" x:Name="ResumeButton" Content="Tiếp tục" Click="Resume_Click" />
        <Button Grid.Column="4" x:Name="RetryButton" Content="Thử lại" Click="Retry_Click" />
        <Button Grid.Column="5" x:Name="CancelButton" Content="Hủy tác vụ" Click="Cancel_Click" IsEnabled="False" />
      </Grid>
    </Border>
  </Grid>
</Window>
