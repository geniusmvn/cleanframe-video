<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Erasa.Video.App.Controls"
        x:Class="Erasa.Video.App.MainWindow"
        Width="1440" Height="860" MinWidth="1180" MinHeight="720"
        WindowStartupLocation="CenterScreen" Title="ERASA VIDEO"
        Icon="/Assets/erasa.ico" Background="#F7F5F2" DragDrop.AllowDrop="True">
  <Grid RowDefinitions="88,46,*,86">
    <Border Grid.Row="0" Background="White" BorderBrush="#E8E3DE" BorderThickness="0,0,0,1" Padding="22,12">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="18">
        <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
          <Image Source="/Assets/erasa-icon.png" Width="52" Height="52" />
          <StackPanel VerticalAlignment="Center" Spacing="3">
            <StackPanel Orientation="Horizontal" Spacing="9">
              <TextBlock Text="ERASA VIDEO" FontSize="23" FontWeight="Bold" Foreground="#171717" />
              <Border Background="#FFF1E7" BorderBrush="#FF6B00" BorderThickness="1" CornerRadius="5" Padding="6,2" VerticalAlignment="Center">
                <TextBlock Text="v0.3.0" Foreground="#FF6B00" FontSize="11" FontWeight="Bold" />
              </Border>
            </StackPanel>
            <TextBlock Text="LaMa gốc • Xóa vật thể theo mask do người dùng xác nhận" Foreground="#766F69" FontSize="12" />
          </StackPanel>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
          <Button Content="Chọn tệp" Click="AddFiles_Click" Classes="header" />
          <Button Content="Thêm thư mục" Click="AddFolder_Click" Classes="header" />
          <Button Content="Mở thư mục gốc" Click="OpenSourceFolder_Click" Classes="header" />
          <Button Content="Thư mục lưu" Click="OpenOutputFolder_Click" Classes="header" />
          <Button Content="Cài đặt" Click="Settings_Click" Classes="header" />
          <Button Content="Thoát" Click="Exit_Click" Classes="header" />
        </StackPanel>
      </Grid>
    </Border>

    <Border Grid.Row="1" Background="White" BorderBrush="#E8E3DE" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="120,120,*,Auto" Margin="20,0" ColumnSpacing="2">
        <Button x:Name="VideoTab" Content="Video" Classes="tab selected" Click="VideoTab_Click" />
        <Button Grid.Column="1" x:Name="ImageTab" Content="Ảnh" Classes="tab" Click="ImageTab_Click" />
        <TextBlock Grid.Column="2" x:Name="RuntimeStatusText" Text="Đang kiểm tra bộ xử lý…" VerticalAlignment="Center" Foreground="#766F69" Margin="18,0,0,0" />
        <TextBlock Grid.Column="3" x:Name="SelectedCountText" Text="Chưa chọn tệp" VerticalAlignment="Center" Foreground="#766F69" />
      </Grid>
    </Border>

    <Grid Grid.Row="2" ColumnDefinitions="*,360" ColumnSpacing="12" Margin="14,12,14,10">
      <Border Classes="card" Padding="10">
        <Grid RowDefinitions="52,*,84,44,Auto" RowSpacing="8">
          <Border Background="#FBF8F4" CornerRadius="9" BorderBrush="#E8E2DC" BorderThickness="1" Padding="10,7">
            <Grid ColumnDefinitions="108,Auto,Auto,*,Auto" ColumnSpacing="8">
              <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Border Width="28" Height="28" CornerRadius="6" Background="#FF6B00">
                  <TextBlock Text="1" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" />
                </Border>
                <TextBlock Text="CÁCH XÓA" FontWeight="Bold" VerticalAlignment="Center" />
              </StackPanel>
              <Button Grid.Column="1" x:Name="AutoButton" Classes="primary" Content="Tự động đề xuất" Click="Suggest_Click" />
              <Button Grid.Column="2" x:Name="ManualButton" Content="Chọn vùng thủ công" Click="Manual_Click" />
              <TextBlock Grid.Column="3" x:Name="SelectionStateText" Text="Chưa chọn tệp" VerticalAlignment="Center" Foreground="#6F6862" Margin="8,0" />
              <Border Grid.Column="4" Background="#1E2227" CornerRadius="5" Padding="8,3" VerticalAlignment="Center">
                <TextBlock Text="PREVIEW" Foreground="White" FontSize="10" FontWeight="Bold" />
              </Border>
            </Grid>
          </Border>

          <Grid Grid.Row="1" Background="#080A0D" ClipToBounds="True">
            <controls:MaskEditor x:Name="Editor" MinWidth="600" MinHeight="340" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
            <Border x:Name="EmptyState" Background="#0B0E12" IsHitTestVisible="False">
              <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                <Border Width="60" Height="60" CornerRadius="16" Background="#181D23">
                  <TextBlock Text="＋" FontSize="34" Foreground="#FF7A1A" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <TextBlock Text="Thả ảnh hoặc video vào đây" Foreground="White" FontSize="19" FontWeight="SemiBold" HorizontalAlignment="Center" />
                <TextBlock Text="Hoặc bấm Chọn tệp ở góc trên" Foreground="#9DA4AC" FontSize="12" HorizontalAlignment="Center" />
              </StackPanel>
            </Border>
            <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10" Background="#D7191D23" CornerRadius="5" Padding="8,4" IsHitTestVisible="False">
              <TextBlock x:Name="CanvasModeText" Text="CỌ" Foreground="White" FontSize="10" FontWeight="Bold" />
            </Border>
          </Grid>

          <Grid Grid.Row="2" RowDefinitions="40,36" ColumnDefinitions="*,Auto" ColumnSpacing="10">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Button x:Name="BrushTool" Classes="tool selected" Content="Cọ" Click="Tool_Click" Tag="Brush" />
              <Button x:Name="EraserTool" Classes="tool" Content="Tẩy" Click="Tool_Click" Tag="Eraser" />
              <Button x:Name="RectTool" Classes="tool" Content="Khung" Click="Tool_Click" Tag="Rectangle" />
              <Button x:Name="EllipseTool" Classes="tool" Content="Elip" Click="Tool_Click" Tag="Ellipse" />
              <Button x:Name="PanTool" Classes="tool" Content="Pan" Click="Tool_Click" Tag="Pan" />
              <TextBlock Text="Cỡ cọ" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="#625C56" />
              <Slider x:Name="BrushSlider" Minimum="0.004" Maximum="0.10" Value="0.025" Width="120" ValueChanged="BrushSlider_Changed" />
              <TextBlock Text="Mềm" VerticalAlignment="Center" Foreground="#625C56" />
              <Slider x:Name="SoftnessSlider" Minimum="0" Maximum="1" Value="0.2" Width="92" ValueChanged="SoftnessSlider_Changed" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
              <Button Content="Hoàn tác" Click="Undo_Click" Classes="compact" />
              <Button Content="Làm lại" Click="Redo_Click" Classes="compact" />
              <Button Content="Đặt lại" Click="ClearMask_Click" Classes="compact" />
            </StackPanel>
            <Grid Grid.Row="1" Grid.ColumnSpan="2" ColumnDefinitions="44,*,54,Auto,52,Auto" ColumnSpacing="8">
              <TextBlock x:Name="CurrentTimeText" Text="00:00" VerticalAlignment="Center" Foreground="#625C56" />
              <Slider Grid.Column="1" x:Name="Timeline" Minimum="0" Maximum="1" Value="0" ValueChanged="Timeline_Changed" />
              <TextBlock Grid.Column="2" x:Name="DurationText" Text="00:00" VerticalAlignment="Center" Foreground="#625C56" />
              <Button Grid.Column="3" Content="−" Click="ZoomOut_Click" Classes="square" />
              <TextBlock Grid.Column="4" x:Name="ZoomText" Text="100%" VerticalAlignment="Center" TextAlignment="Center" />
              <Button Grid.Column="5" Content="+" Click="ZoomIn_Click" Classes="square" />
            </Grid>
          </Grid>

          <Grid Grid.Row="3" ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
            <TextBlock x:Name="HintText" Text="Thêm tệp để bắt đầu." VerticalAlignment="Center" Foreground="#655E58" TextTrimming="CharacterEllipsis" />
            <Button Grid.Column="1" x:Name="ConfirmMaskButton" Classes="confirm" Content="Xác nhận mask" Click="ConfirmMask_Click" />
            <Button Grid.Column="2" x:Name="PreviewButton" Content="Preview 3 giây" Click="Preview_Click" />
            <Button Grid.Column="3" x:Name="RescanButton" Content="Quét lại" Click="Suggest_Click" />
          </Grid>

          <Border Grid.Row="4" x:Name="ErrorPanel" Background="#FFF2F0" BorderBrush="#F2B8B2" BorderThickness="1" CornerRadius="8" Padding="10" IsVisible="False">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="9">
              <TextBlock Text="!" Foreground="#B42318" FontWeight="Bold" FontSize="18" VerticalAlignment="Center" />
              <TextBlock Grid.Column="1" x:Name="ErrorText" Text="" Foreground="#8E1B12" TextWrapping="Wrap" VerticalAlignment="Center" />
              <Button Grid.Column="2" Content="Thử đọc lại" Click="RetryLoad_Click" Classes="compact" />
              <Button Grid.Column="3" Content="Mở log" Click="OpenLog_Click" Classes="compact" />
            </Grid>
          </Border>
        </Grid>
      </Border>

      <Border Grid.Column="1" Classes="card" Padding="12">
        <Grid RowDefinitions="44,*,36" RowSpacing="8">
          <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <TextBlock Text="Danh sách xử lý" FontSize="18" FontWeight="Bold" />
              <Border Background="#F2EFEC" CornerRadius="9" Padding="8,3">
                <TextBlock x:Name="QueueCountText" Text="0 tệp" Foreground="#756E68" />
              </Border>
            </StackPanel>
            <Button Grid.Column="1" Content="Thêm" Click="AddFiles_Click" Classes="compact" />
            <Button Grid.Column="2" Content="Bỏ danh sách" Click="ClearQueue_Click" Classes="compact" />
          </Grid>

          <ListBox Grid.Row="1" x:Name="QueueList" SelectionChanged="QueueList_SelectionChanged" Background="Transparent" BorderThickness="0" SelectionMode="Single">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border Classes="queue" Margin="0,0,0,8" Padding="8">
                  <Grid ColumnDefinitions="38,86,*,Auto" ColumnSpacing="9">
                    <Border Background="#FFF1E7" CornerRadius="7" Width="38" Height="38" VerticalAlignment="Top">
                      <TextBlock Text="{Binding QueueNumberText}" FontSize="12" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center" Foreground="#FF6B00" />
                    </Border>
                    <Border Grid.Column="1" Background="#111419" CornerRadius="6" Width="86" Height="54" ClipToBounds="True">
                      <Image Source="{Binding PreviewPath, Converter={StaticResource PathBitmapConverter}}" Stretch="UniformToFill" />
                    </Border>
                    <StackPanel Grid.Column="2" Spacing="2">
                      <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                      <TextBlock Text="{Binding MetadataText}" FontSize="11" Foreground="#756E68" />
                      <TextBlock Text="{Binding StatusText}" FontSize="11" Foreground="#A64518" TextTrimming="CharacterEllipsis" />
                      <ProgressBar Minimum="0" Maximum="1" Value="{Binding Progress}" Height="3" Margin="0,2,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="3" Spacing="6" HorizontalAlignment="Right">
                      <Border Background="#F3F0ED" CornerRadius="6" Padding="6,3">
                        <TextBlock Text="{Binding StatusShortText}" FontSize="10" FontWeight="SemiBold" />
                      </Border>
                      <Button Content="×" Click="RemoveItem_Click" Tag="{Binding}" Classes="remove" />
                    </StackPanel>
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <TextBlock Grid.Row="2" Text="Kéo thả tệp hoặc thư mục vào cửa sổ để thêm nhanh." TextWrapping="Wrap" Foreground="#817970" FontSize="11" VerticalAlignment="Center" />
        </Grid>
      </Border>
    </Grid>

    <Border Grid.Row="3" Margin="14,0,14,12" Classes="card" Padding="11">
      <Grid ColumnDefinitions="176,*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
        <Button x:Name="ProcessButton" Classes="primary process" Content="XỬ LÝ" FontSize="20" Click="Process_Click" />
        <Grid Grid.Column="1" RowDefinitions="Auto,Auto" VerticalAlignment="Center">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
            <TextBlock x:Name="StatusText" Text="Sẵn sàng" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
            <TextBlock Grid.Column="1" x:Name="BatchProgressText" Text="0 / 0 hoàn thành" FontWeight="SemiBold" />
          </Grid>
          <ProgressBar Grid.Row="1" x:Name="BatchProgress" Minimum="0" Maximum="1" Height="7" Margin="0,8,0,0" />
        </Grid>
        <Button Grid.Column="2" x:Name="PauseButton" Content="Tạm dừng" Click="Pause_Click" IsEnabled="False" />
        <Button Grid.Column="3" x:Name="ResumeButton" Content="Tiếp tục" Click="Resume_Click" />
        <Button Grid.Column="4" x:Name="RetryButton" Content="Thử lại" Click="Retry_Click" />
        <Button Grid.Column="5" x:Name="CancelButton" Content="Hủy" Click="Cancel_Click" IsEnabled="False" />
      </Grid>
    </Border>
  </Grid>
</Window>
