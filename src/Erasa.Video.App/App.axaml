<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="using:Erasa.Video.App.Services"
             x:Class="Erasa.Video.App.App"
             RequestedThemeVariant="Light">
  <Application.Resources>
    <services:PathBitmapConverter x:Key="PathBitmapConverter" />
  </Application.Resources>
  <Application.Styles>
    <FluentTheme />
    <Style Selector="Window">
      <Setter Property="FontFamily" Value="avares://Avalonia.Fonts.Inter/Assets#Inter" />
      <Setter Property="Background" Value="#F7F5F2" />
    </Style>
    <Style Selector="Button">
      <Setter Property="CornerRadius" Value="7" />
      <Setter Property="Padding" Value="13,8" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Background" Value="#F3F0ED" />
      <Setter Property="BorderBrush" Value="#DED8D2" />
      <Setter Property="Foreground" Value="#26221F" />
    </Style>
    <Style Selector="Button:pointerover">
      <Setter Property="Opacity" Value="0.90" />
    </Style>
    <Style Selector="Button.header">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="11,8" />
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="#FF6B00" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderBrush" Value="#FF6B00" />
    </Style>
    <Style Selector="Button.confirm">
      <Setter Property="Background" Value="#171A1F" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderBrush" Value="#171A1F" />
    </Style>
    <Style Selector="Button.tool">
      <Setter Property="Background" Value="#FFF9F4" />
      <Setter Property="BorderBrush" Value="#E8DED6" />
      <Setter Property="Padding" Value="12,7" />
    </Style>
    <Style Selector="Button.tool.selected">
      <Setter Property="Background" Value="#FF6B00" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="BorderBrush" Value="#FF6B00" />
    </Style>
    <Style Selector="Button.tab">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="Foreground" Value="#5E5751" />
    </Style>
    <Style Selector="Button.tab.selected">
      <Setter Property="Foreground" Value="#FF6B00" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>
    <Style Selector="Button.compact">
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="Button.square">
      <Setter Property="Width" Value="32" />
      <Setter Property="Height" Value="28" />
      <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="Button.remove">
      <Setter Property="Width" Value="28" />
      <Setter Property="Height" Value="26" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="Button.process">
      <Setter Property="MinHeight" Value="54" />
    </Style>
    <Style Selector="Border.card">
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="#E3DED9" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="11" />
    </Style>
    <Style Selector="Border.queue">
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="#DED8D2" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="9" />
    </Style>
    <Style Selector="ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ListBoxItem:selected">
      <Setter Property="Background" Value="#FFF4EB" />
    </Style>
  </Application.Styles>
</Application>
