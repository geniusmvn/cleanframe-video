<Window
    x:Class="Erasa.Video2.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Erasa.Video2.App.Controls"
    xmlns:viewModels="using:Erasa.Video2.App.ViewModels"
    Title="ERASA VIDEO">

    <Grid x:Name="RootGrid" Background="#FFF7F6F4" AllowDrop="True" DragOver="Root_DragOver" Drop="Root_Drop">
        <Grid.RowDefinitions>
            <RowDefinition Height="92" />
            <RowDefinition Height="46" />
            <RowDefinition Height="*" />
            <RowDefinition Height="82" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource ErasaBorderBrush}" BorderThickness="0,0,0,1">
            <Grid Padding="24,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                    <Image Source="Assets/erasa-icon.png" Width="48" Height="58" Stretch="Uniform" />
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="ERASA VIDEO" FontSize="23" FontWeight="Bold" Foreground="{StaticResource ErasaInkBrush}" />
                            <Border Background="#FFFFE8D9" CornerRadius="5" Padding="7,2" VerticalAlignment="Center">
                                <TextBlock Text="v1.0.0" Foreground="{StaticResource ErasaOrangeBrush}" FontSize="11" FontWeight="SemiBold" />
                            </Border>
                        </StackPanel>
                        <TextBlock Text="LaMa gốc • Temporal video • Mask do người dùng xác nhận" Foreground="{StaticResource ErasaMutedBrush}" FontSize="12" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <Button x:Name="AddFilesButton" Content="Chọn tệp" Style="{StaticResource SecondaryButtonStyle}" Click="AddFiles_Click" />
                    <Button x:Name="AddFolderButton" Content="Thêm thư mục" Style="{StaticResource SecondaryButtonStyle}" Click="AddFolder_Click" />
                    <Button x:Name="OpenSourceButton" Content="Mở thư mục gốc" Style="{StaticResource SecondaryButtonStyle}" Click="OpenSource_Click" />
                    <Button x:Name="OutputFolderButton" Content="Thư mục lưu" Style="{StaticResource SecondaryButtonStyle}" Click="OutputFolder_Click" />
                    <Button x:Name="SettingsButton" Content="Cài đặt" Style="{StaticResource SecondaryButtonStyle}" Click="Settings_Click" />
                    <Button x:Name="ExitButton" Content="Thoát" Style="{StaticResource SecondaryButtonStyle}" Click="Exit_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource ErasaBorderBrush}" BorderThickness="0,0,0,1">
            <Grid Padding="20,5">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <ToggleButton x:Name="VideoTabButton" Content="Video" IsChecked="True" Style="{StaticResource ToolToggleStyle}" Click="VideoTab_Click" />
                    <ToggleButton x:Name="ImageTabButton" Content="Ảnh" Style="{StaticResource ToolToggleStyle}" Click="ImageTab_Click" />
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Border x:Name="RuntimeBadge" Background="#FFF1EFEC" CornerRadius="10" Padding="10,4">
                        <TextBlock x:Name="RuntimeText" Text="Đang kiểm tra LaMa…" FontSize="12" Foreground="{StaticResource ErasaMutedBrush}" />
                    </Border>
                    <TextBlock x:Name="SelectedCountText" Text="Chưa chọn tệp" Foreground="{StaticResource ErasaMutedBrush}" FontSize="12" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Padding="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="{StaticResource ErasaBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="10" Margin="0,0,8,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="48" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="48" />
                        <RowDefinition Height="44" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{StaticResource ErasaSurfaceBrush}" CornerRadius="9" BorderBrush="{StaticResource ErasaBorderBrush}" BorderThickness="1" Padding="10,6">
                        <Grid>
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <Border Background="{StaticResource ErasaOrangeBrush}" CornerRadius="6" Width="28" Height="28">
                                    <TextBlock Text="1" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="CÁCH XÓA" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <Button x:Name="SuggestButton" Content="Tự động đề xuất" Style="{StaticResource PrimaryButtonStyle}" Click="Suggest_Click" />
                                <Button x:Name="ManualButton" Content="Chọn vùng thủ công" Style="{StaticResource SecondaryButtonStyle}" Click="Manual_Click" />
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <ComboBox x:Name="QualityCombo" Width="125" SelectionChanged="Quality_Changed">
                                    <ComboBoxItem Content="Beautiful" IsSelected="True" />
                                    <ComboBoxItem Content="Fast" />
                                </ComboBox>
                                <Border Background="#FF1A1B1E" CornerRadius="4" Padding="8,3">
                                    <TextBlock x:Name="ViewModeText" Text="CHỈNH MASK" Foreground="White" FontSize="10" FontWeight="Bold" />
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Background="#FF15171A" CornerRadius="10" Margin="0,8,0,8">
                        <Grid>
                            <ScrollViewer x:Name="EditorScroll" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" ZoomMode="Enabled" MinZoomFactor="0.25" MaxZoomFactor="4" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                                <Grid x:Name="ImageSurface" Width="1280" Height="720" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Image x:Name="SourceImage" Stretch="Fill" />
                                    <controls:MaskEditor x:Name="Editor" />
                                </Grid>
                            </ScrollViewer>
                            <Grid x:Name="EmptyState" Background="#FF15171A">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                                    <Image Source="Assets/erasa-icon.png" Width="74" Height="90" Opacity="0.65" />
                                    <TextBlock Text="Thả ảnh hoặc video vào đây" Foreground="White" FontSize="17" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                    <TextBlock Text="Preview luôn được giữ lại khi worker lỗi." Foreground="#FFAEB2B8" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                            <MediaPlayerElement x:Name="PreviewPlayer" AreTransportControlsEnabled="True" AutoPlay="True" Visibility="Collapsed" />
                            <Grid x:Name="BusyOverlay" Background="#66000000" Visibility="Collapsed">
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                                    <ProgressRing x:Name="BusyRing" IsActive="True" Width="42" Height="42" Foreground="{StaticResource ErasaOrangeBrush}" />
                                    <TextBlock x:Name="BusyText" Text="Đang xử lý…" Foreground="White" FontWeight="SemiBold" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <ToggleButton x:Name="BrushTool" Content="Cọ" IsChecked="True" Style="{StaticResource ToolToggleStyle}" Click="BrushTool_Click" />
                            <ToggleButton x:Name="EraserTool" Content="Tẩy" Style="{StaticResource ToolToggleStyle}" Click="EraserTool_Click" />
                            <ToggleButton x:Name="RectangleTool" Content="Khung" Style="{StaticResource ToolToggleStyle}" Click="RectangleTool_Click" />
                            <ToggleButton x:Name="EllipseTool" Content="Elip" Style="{StaticResource ToolToggleStyle}" Click="EllipseTool_Click" />
                            <ToggleButton x:Name="PanTool" Content="Pan" Style="{StaticResource ToolToggleStyle}" Click="PanTool_Click" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Cỡ cọ" VerticalAlignment="Center" Foreground="{StaticResource ErasaMutedBrush}" />
                            <Slider x:Name="BrushSizeSlider" Width="120" Minimum="0.005" Maximum="0.08" Value="0.025" ValueChanged="BrushSize_Changed" />
                            <TextBlock Text="Mềm" VerticalAlignment="Center" Foreground="{StaticResource ErasaMutedBrush}" />
                            <Slider x:Name="SoftnessSlider" Width="100" Minimum="0" Maximum="1" Value="0.2" ValueChanged="Softness_Changed" />
                        </StackPanel>
                        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Button x:Name="UndoButton" Content="Hoàn tác" Style="{StaticResource SecondaryButtonStyle}" Click="Undo_Click" />
                            <Button x:Name="RedoButton" Content="Làm lại" Style="{StaticResource SecondaryButtonStyle}" Click="Redo_Click" />
                            <Button x:Name="ResetButton" Content="Đặt lại" Style="{StaticResource SecondaryButtonStyle}" Click="Reset_Click" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="CurrentTimeText" Text="00:00" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <Slider x:Name="Timeline" Grid.Column="1" Minimum="0" Maximum="1" ValueChanged="Timeline_Changed" />
                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" Margin="10,0" VerticalAlignment="Center">
                            <TextBlock x:Name="DurationText" Text="00:00" VerticalAlignment="Center" />
                            <Button Content="−" Width="34" Height="34" Style="{StaticResource SecondaryButtonStyle}" Click="ZoomOut_Click" />
                            <TextBlock x:Name="ZoomText" Text="100%" Width="44" TextAlignment="Center" VerticalAlignment="Center" />
                            <Button Content="+" Width="34" Height="34" Style="{StaticResource SecondaryButtonStyle}" Click="ZoomIn_Click" />
                        </StackPanel>
                        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6">
                            <Button x:Name="ConfirmMaskButton" Content="Xác nhận mask" Style="{StaticResource PrimaryButtonStyle}" Click="ConfirmMask_Click" />
                            <Button x:Name="PreviewButton" Content="Preview 3 giây" Style="{StaticResource SecondaryButtonStyle}" Click="Preview_Click" />
                            <Button x:Name="ReloadFrameButton" Content="Quét lại" Style="{StaticResource SecondaryButtonStyle}" Click="ReloadFrame_Click" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="White" BorderBrush="{StaticResource ErasaBorderBrush}" BorderThickness="1" CornerRadius="12" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="48" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="42" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <TextBlock Text="Danh sách xử lý" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" Spacing="6">
                            <Button Content="Thêm" Style="{StaticResource SecondaryButtonStyle}" Click="AddFiles_Click" />
                            <Button Content="Bỏ danh sách" Style="{StaticResource SecondaryButtonStyle}" Click="ClearQueue_Click" />
                        </StackPanel>
                    </Grid>
                    <ListView x:Name="QueueList" Grid.Row="1" SelectionMode="Single" SelectionChanged="QueueList_SelectionChanged" ItemsSource="{x:Bind Jobs}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:JobViewModel">
                                <Border BorderBrush="{StaticResource ErasaBorderBrush}" BorderThickness="1" CornerRadius="9" Padding="8" Margin="0,0,0,7" Background="White">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="32" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="74" Height="48" Background="#FF1A1B1E" CornerRadius="6">
                                            <Image Source="{x:Bind Thumbnail, Mode=OneWay}" Stretch="UniformToFill" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="8,0" Spacing="2" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind FileName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{x:Bind Details}" FontSize="11" Foreground="{StaticResource ErasaMutedBrush}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{x:Bind StateText, Mode=OneWay}" FontSize="11" Foreground="{StaticResource ErasaOrangeBrush}" />
                                            <ProgressBar Value="{x:Bind Progress, Mode=OneWay}" Maximum="100" Height="3" />
                                        </StackPanel>
                                        <Button Grid.Column="2" Content="×" Width="28" Height="28" Padding="0" Tag="{Binding}" Click="RemoveJob_Click" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <TextBlock Grid.Row="2" Text="Kéo nhiều tệp hoặc cả thư mục vào cửa sổ." Foreground="{StaticResource ErasaMutedBrush}" FontSize="11" VerticalAlignment="Center" />
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Background="White" BorderBrush="{StaticResource ErasaBorderBrush}" BorderThickness="1,1,1,0" CornerRadius="12,12,0,0" Margin="10,0,10,0" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button x:Name="ProcessButton" Content="XỬ LÝ" FontSize="18" Style="{StaticResource PrimaryButtonStyle}" Click="Process_Click" />
                <StackPanel Grid.Column="1" Margin="16,0" VerticalAlignment="Center" Spacing="5">
                    <TextBlock x:Name="OverallStatusText" Text="Thêm tệp để bắt đầu." FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                    <ProgressBar x:Name="OverallProgress" Height="7" Minimum="0" Maximum="100" />
                    <InfoBar x:Name="ErrorBar" IsOpen="False" Severity="Error" IsClosable="True" />
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Button x:Name="PauseButton" Content="Tạm dừng" Style="{StaticResource SecondaryButtonStyle}" Click="Pause_Click" />
                    <Button x:Name="ResumeButton" Content="Tiếp tục" Style="{StaticResource SecondaryButtonStyle}" Click="Resume_Click" />
                    <Button x:Name="RetryButton" Content="Thử lại" Style="{StaticResource SecondaryButtonStyle}" Click="Retry_Click" />
                    <Button x:Name="CancelButton" Content="Hủy tác vụ" Style="{StaticResource SecondaryButtonStyle}" Click="Cancel_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
